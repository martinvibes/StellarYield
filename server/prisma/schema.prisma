generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @default(uuid())
  ledger          Int
  txHash          String
  contractId      String
  topic           String
  data            String   // XDR encoded or parsed JSON
  createdAt       DateTime @default(now())

  @@unique([txHash, topic, data]) // Idempotency
}

model IndexerState {
  id              String   @id @default("singleton")
  lastLedger      Int
}
